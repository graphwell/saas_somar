generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified DateTime?           // Exigido pelo PrismaAdapter (NextAuth)
  image         String?             // Exigido pelo PrismaAdapter (NextAuth)
  password      String?             // Nullable para suportar login via Google OAuth
  role          UserRole  @default(USER)

  // NextAuth OAuth
  accounts Account[]

  // Relacionamentos Multi-tenant
  subscription  Subscription?
  instances     WhatsAppInstance[]
  agents        Agent[]
  customers     Customer[]
  waitingQueue  WaitingQueue?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tabela necessária para OAuth (Google, etc.)
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ==========================================
// PILAR: MONETIZAÇÃO E LIMITES
// ==========================================
model Subscription {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  planType String @default("trial") // trial, starter, pro
  status   String @default("active") // active, past_due, canceled

  messagesLimit Int @default(100)
  messagesUsed  Int @default(0)

  tokensLimit   Int @default(100000) // Default token limit
  tokensUsed    Int @default(0)

  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime? // Optional until they actually subscribe

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// PILAR: ARQUITETURA DE INSTÂNCIAS E AGENTES
// ==========================================
enum Provider {
  ULTRAMSG
  WASENDER
}

enum InstanceStatus {
  IDLE
  IN_USE
  DISABLED
}

enum InstancePlan {
  TRIAL
  PAID
}

model WhatsAppInstance {
  id     String @id @default(uuid())
  userId String? @unique
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String // Ex: "Vendas" ou "Suporte"
  provider    Provider
  instanceKey String @unique // ID no provedor (provider ID)
  token       String // API Token

  status      InstanceStatus @default(IDLE)
  plan        InstancePlan @default(TRIAL)
  messageCount Int @default(0)

  // 1 Instância roda 1 Agente
  agentId String? @unique
  agent   Agent?  @relation(fields: [agentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String // Ex: "Atendente Padrão"
  systemPrompt String @db.Text
  temperature  Float  @default(0.7)
  isActive     Boolean @default(true)

  lastEditedBy String? // "USER" or "ADMIN - nome"
  lastEditedAt DateTime?

  instance WhatsAppInstance?
  responseCache AgentResponseCache[]
  auditLogs     AgentAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// PILAR: MEMÓRIA, HISTÓRICO E HANDOFF
// ==========================================
model Customer {
  id     String @id @default(uuid())
  userId String // Multi-tenant: Dono deste lead
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone String
  name  String?

  sessions ChatSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, phone]) // Mesmo cliente pode existir para empresas diferentes
}

model ChatSession {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Controle de Transbordo (Handoff)
  status String @default("active") // active, human_handoff, closed

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role    String // "user" (cliente final), "assistant" (IA), "system" (avisos internos)
  content String @db.Text

  tokensUsed Int @default(0) // Auditoria de custo da OpenAI

  createdAt DateTime @default(now())
}

// ==========================================
// PILAR: NOTIFICAÇÕES ADMIN
// ==========================================
enum NotificationType {
  TRIAL_POOL_EMPTY
  TRIAL_POOL_LOW
  PAID_POOL_EMPTY
  PAID_POOL_LOW
  INSTANCE_DISCONNECTED
  NO_PAID_INSTANCE
  INSTANCE_READY
}

model AdminNotification {
  id        String           @id @default(uuid())
  type      NotificationType
  message   String
  userId    String?          // Usuário que disparou o alerta (se houver)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
}

// Fila de espera quando pool está vazio
model WaitingQueue {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("TRIAL")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Idempotência do webhook Stripe
model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
}

// ==========================================
// PILAR: OTIMIZAÇÃO E AUDITORIA (NOVO)
// ==========================================
model AgentResponseCache {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  query     String   @db.Text
  response  String   @db.Text
  
  createdAt DateTime @default(now())

  @@index([agentId, query])
}

model AgentAuditLog {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  editedBy  String   // Ex: "USER", "ADMIN - João"
  action    String   // Ex: "UPDATE_PROMPT", "UPDATE_TEMPERATURE"
  
  createdAt DateTime @default(now())
}
